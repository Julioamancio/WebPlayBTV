# Core application settings
APP_NAME=WEBplayer JTV API
DATABASE_URL=sqlite:///./webplay.db

# Security (sempre substitua por valores próprios antes de subir para produção)
JWT_SECRET=change-me-in-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# ALLOW_INSECURE_DEFAULTS=1  # Habilite somente em desenvolvimento para aceitar segredos de exemplo.

# Networking
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,file://

# Streaming proxy
COOKIE_JAR_MAX=32
COOKIE_JAR_TTL_SECONDS=3600

# Paths
# FRONTEND_DIRECTORY=../frontend

